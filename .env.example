# Pawtner API local dev environment
# Copy to .env and adjust secrets as needed.

# PostgreSQL connection (app DB)
DATABASE_URL=postgres://pawtner:dev-secret@localhost:5432/pawtner_db

# Keycloak realm configuration
# Issuer MUST be the realm root (no /account at the end)
KEYCLOAK_ISSUER=http://localhost:8080/realms/pawtner
# Optional: override JWKS URI; normally derived from KEYCLOAK_ISSUER
# KEYCLOAK_JWKS_URI=http://localhost:8080/realms/pawtner/protocol/openid-connect/certs

# Audience expected in the access token's `aud` claim.
# For now this should match what Keycloak puts in `aud` (often `account` by default),
# or a client ID if you configure audiences accordingly.
KEYCLOAK_AUDIENCE=account

# API network settings
PORT=3000
#BIND_ADDR=0.0.0.0:3000

